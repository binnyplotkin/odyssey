# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# turbo
.turbo

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.generated/
.local/
tmp-app/
.world-session-audio/

# Voice-actor source clips. The deployable artifact is the .safetensors
# embedding committed under services/audio-rt/voices/; the raw mp3/wav
# source stays local-only to avoid distributing actor audio without an
# explicit consent paper trail.
apps/admin/public/voice/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eval runs (machine + human-readable per-run reports)
/.evals/

# Sonar latency benchmark raw run records (ledger is committed under evals/sonar/)
/.sonar/

# Sonar synthesized input fixtures (regenerable via `sonar synth`; ledger stays committed)
evals/sonar/fixtures/*.wav
