# --- LiveKit (required for the worker to register + join rooms) ---
# Create a LiveKit Cloud project (or self-host) and copy its URL + API key/secret.
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Character + STT (A2: the worker voices ONE character) ---
# Which character this worker speaks as — id or slug that runVoiceStream resolves.
VOICE_AGENT_CHARACTER_ID=abraham
# STT via LiveKit Inference (billed through LiveKit — NO separate STT key needed).
# e.g. deepgram/nova-3 | assemblyai/universal-streaming | deepgram/nova-2 …
VOICE_AGENT_STT=deepgram/nova-3

# Railway healthcheck port (the agents worker doesn't serve HTTP itself).
HEALTH_PORT=8080

# bge runs warm in-process (warmLocalEmbedder) — leave EMBEDDING_PROVIDER unset.

# --- REQUIRED now (A2 is wired): runVoiceStream (the brain) needs the same runtime
# env as services/voice-host. Mirror it here:
# DATABASE_URL, CEREBRAS_API_KEY, GROQ_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY,
# ELEVENLABS_API_KEY, CARTESIA_API_KEY, KYUTAI_TTS_BASE_URL, SUPABASE_URL,
# SUPABASE_SECRET_KEY, VOICE_ACK_LANE, etc.
