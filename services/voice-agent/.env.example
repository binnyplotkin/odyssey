# --- LiveKit (required for the worker to register + join rooms) ---
# Create a LiveKit Cloud project (or self-host) and copy its URL + API key/secret.
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Railway healthcheck port (the agents worker doesn't serve HTTP itself).
HEALTH_PORT=8080

# bge runs warm in-process (warmLocalEmbedder) — leave EMBEDDING_PROVIDER unset.

# --- A2+ only: once runVoiceStream (the brain) is wired in, this service also needs
# the voice-host runtime env. Mirror services/voice-host's env at that point:
# DATABASE_URL, CEREBRAS_API_KEY, GROQ_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY,
# ELEVENLABS_API_KEY, CARTESIA_API_KEY, KYUTAI_TTS_BASE_URL, SUPABASE_URL,
# SUPABASE_SECRET_KEY, VOICE_ACK_LANE, etc.
