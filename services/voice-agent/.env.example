# services/voice-agent — environment.
# Run: npx tsx --env-file=services/voice-agent/.env services/voice-agent/src/agent.ts dev
#
# Vars are grouped REQUIRED / RECOMMENDED / OPTIONAL. The brain block (DATABASE_URL +
# the LLM/TTS/Supabase keys) is byte-identical to what services/voice-host runs in
# prod — the fastest path is to copy those values from your voice-host deploy.

# ============================== REQUIRED ==============================

# --- LiveKit worker (read by @livekit/agents itself; the worker won't register
#     without them). Create a project at cloud.livekit.io → Settings → Keys. ---
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Which character this worker voices (id or slug runVoiceStream resolves). ---
VOICE_AGENT_CHARACTER_ID=abraham

# --- The brain (runVoiceStream) — knowledge graph + the default Abraham voice path. ---
DATABASE_URL=                 # Postgres/Neon: the knowledge graph + voice sessions
CEREBRAS_API_KEY=             # Abraham's LLM (gpt-oss-120b)
ELEVENLABS_API_KEY=           # Abraham's voice (james-husky, provider=elevenlabs)
SUPABASE_URL=                 # voices table + audio storage
SUPABASE_SECRET_KEY=          # ...or SUPABASE_SERVICE_ROLE_KEY (either is accepted)

# ============================= RECOMMENDED ===========================
# Fallbacks — set if you have them (harmless if pasted, avoid surprise failures).

OPENAI_API_KEY=               # embed fallback (won't fire with warm bge) + some paths
GROQ_API_KEY=                 # alternate LLM provider
ANTHROPIC_API_KEY=            # provider / orchestrator fallback

# STT via LiveKit Inference — billed through LiveKit, NO separate STT key.
# deepgram/nova-3 | assemblyai/universal-streaming | deepgram/nova-2 | …
VOICE_AGENT_STT=deepgram/nova-3

# ============================== OPTIONAL =============================
# Only needed if you change providers or tune. All have defaults.

# Other TTS providers (Abraham uses ElevenLabs; set only if switching):
# CARTESIA_API_KEY=
# CARTESIA_VERSION=
# CARTESIA_MODEL_ID=
# KYUTAI_TTS_BASE_URL=          # Pocket TTS host
# KYUTAI_BASE_URL=

# ElevenLabs overrides (voice is resolved from the DB — leave unless overriding):
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
# ELEVENLABS_FALLBACK_VOICE_SLUG=
# ELEVENLABS_FALLBACK_VOICE_ID=
# ELEVENLABS_ENFORCE_NORMAL_PRICING=
# ELEVENLABS_ALLOW_PROFESSIONAL_VOICES=

# The dramaturg — async scene reflection writing a director's note the fast
# per-turn director reads (off the voice hot path; failures never touch turns).
# VOICE_AGENT_DRAMATURG=1              # =0 disables entirely
# VOICE_AGENT_DRAMATURG_MODEL=claude-sonnet-4-5  # needs the matching provider key
# VOICE_AGENT_DRAMATURG_EVERY=2        # reflect every N spoken turns

# Scene audio (Phase 2): the world-audio track carrying the ambience bed.
# Default ON — scenes without an authored bed stay silent. Gains are dB.
# VOICE_AGENT_WORLD_AUDIO=1     # =0 kills the world-audio track entirely
# VOICE_AGENT_WORLD_GAIN_DB=-12 # master gain vs the ingest-normalized assets
# VOICE_AGENT_WORLD_DUCK_DB=-12 # extra attenuation while the agent speaks

# Pipeline flags / tuning (sensible defaults if unset):
# TTS_PROVIDER=                 STT_PROVIDER=
# TTS_FALLBACK_PROVIDER=        TTS_ENABLE_FALLBACK=
# TTS_FIRST_AUDIO_TIMEOUT_MS=   VOICE_STREAM_TTS_FALLBACK_PROVIDER=
# VOICE_SEMANTIC_RETRIEVAL=     VOICE_RETRIEVAL_BUDGET_MS=
# VOICE_ACK_LANE=               WIKI_GRAPH_CACHE=
# WS_NO_UTF_8_VALIDATE=         WS_NO_BUFFER_UTIL=

# Railway healthcheck port (the agents worker doesn't serve HTTP itself).
HEALTH_PORT=8080

# Leave EMBEDDING_PROVIDER UNSET → bge runs warm in-process (the whole point of
# this host). Setting it to "openai" forces the cold OpenAI embed path.
