{
  "name": "odyssey",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/run-turbo-stream.mjs dev",
    "dev:web": "node scripts/run-turbo-stream.mjs dev --filter=@odyssey/web",
    "dev:admin": "node scripts/run-turbo-stream.mjs dev --filter=@odyssey/admin",
    "worker:wiki-ingest": "tsx packages/wiki-ingest/src/worker.ts",
    "build": "turbo build",
    "lint": "npm run theme:check && turbo lint",
    "theme:check": "node scripts/check-theme-token-aliases.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "openai": "^6.34.0",
    "turbo": "^2.8.16",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react-feather": "^2.0.10",
    "tsx": "^4.22.3"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "^1.2.4",
    "@img/sharp-libvips-linuxmusl-x64": "^1.2.4",
    "@img/sharp-linux-x64": "^0.34.5",
    "@img/sharp-linuxmusl-x64": "^0.34.5",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1",
    "@tailwindcss/oxide-linux-x64-musl": "^4.2.1",
    "lightningcss-linux-x64-gnu": "^1.29.0",
    "lightningcss-linux-x64-musl": "^1.29.0"
  }
}
