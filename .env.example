DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/odyssey?sslmode=require
OPENAI_API_KEY=sk-example

# Scene turn orchestrator. Leave ORCHESTRATOR_PROVIDER empty to use the first
# configured key in this order: Cerebras, then Groq.
ORCHESTRATOR_PROVIDER=
CEREBRAS_API_KEY=
CEREBRAS_ORCHESTRATOR_MODEL=qwen-3-235b-a22b-instruct-2507
GROQ_API_KEY=
GROQ_ORCHESTRATOR_MODEL=openai/gpt-oss-120b

TTS_PROVIDER=openai
TTS_ENABLE_FALLBACK=false
TTS_FALLBACK_PROVIDER=elevenlabs
VOICE_ACK_LANE=1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
NEXT_PUBLIC_LANDING_HERO_VIDEO_MP4=https://cdn.example.com/landing_page_video_optimized.mp4
NEXT_PUBLIC_LANDING_HERO_VIDEO_HD_MP4=https://scmrwqpkj7u5w0gc.public.blob.vercel-storage.com/videos/odyssey.mp4
NEXT_PUBLIC_LANDING_HERO_VIDEO_WEBM=https://cdn.example.com/landing_page_video_optimized.webm

# Admin core background video. Upload the files from
# `.generated/odyssey-bg-video/` to Supabase Storage and paste the public URLs.
NEXT_PUBLIC_ODYSSEY_CORE_BG_POSTER_URL=
NEXT_PUBLIC_ODYSSEY_CORE_BG_LQIP_URL=
NEXT_PUBLIC_ODYSSEY_CORE_BG_PREVIEW_MP4_URL=
NEXT_PUBLIC_ODYSSEY_CORE_BG_PREVIEW_WEBM_URL=
NEXT_PUBLIC_ODYSSEY_CORE_BG_HD_MP4_URL=
NEXT_PUBLIC_ODYSSEY_CORE_BG_HD_WEBM_URL=

# Supabase Storage — character thumbnail uploads land in the
# `character-thumbnails` bucket. Create one in the Supabase dashboard
# (Storage → New bucket → public) before uploads will work.
#
# SUPABASE_SECRET_KEY is the new name for what used to be called
# `service_role` (Project Settings → API Keys → Secret keys). The route
# also accepts the legacy `SUPABASE_SERVICE_ROLE_KEY` name if your
# project predates the rename.
SUPABASE_URL=https://example.supabase.co
SUPABASE_SECRET_KEY=sb_secret_example_key
