{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo \"skip build for wiki ingest worker\""
  },
  "deploy": {
    "startCommand": "npm run worker:wiki-ingest",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
